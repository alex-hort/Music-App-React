{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",

    "rootDir": "./src",
    "outDir": "./dist",

    "baseUrl": "./",

    "paths": {
      "#/*": ["src/*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "typeRoots": ["./src/@types", "./node_modules/@types"]
  },
  "include": ["src"]
}